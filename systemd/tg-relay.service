[Unit]
Description=Telegram relay proxy
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=tgproxy
Group=tgproxy
WorkingDirectory=/var/lib/tg-relay
ExecStart=/usr/local/bin/tg_relay --config /etc/tg-relay/config.toml
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
AmbientCapabilities=CAP_NET_BIND_SERVICE
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
